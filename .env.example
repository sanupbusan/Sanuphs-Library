# Supabase Cloud
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
# Optional server-only key for future privileged server tasks. Public rent APIs use RPCs and do not require it.
# Never expose it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Admin login alias used by /api/auth/admin/login.
ADMIN_LOGIN_ID=SanupLib
ADMIN_AUTH_EMAIL=sanuplib-admin@sanuplib.local

# Secret used to sign the admin session cookie. Must be at least 32 characters.
# Generate with: openssl rand -base64 32
# Never expose it with NEXT_PUBLIC_.
ADMIN_SESSION_SECRET=<generate-a-random-secret-at-least-32-chars>

# National Library of Korea ISBN lookup API.
# Keep this server-only. Do not prefix with NEXT_PUBLIC_.
NATIONAL_LIBRARY_ISBN_API_KEY=<national-library-isbn-api-key>
# NATIONAL_LIBRARY_ISBN_API_URL=https://www.nl.go.kr/seoji/SearchApi.do

# Optional: keep project metadata in local-only env files if your workflow needs it.
# Do not commit real DB passwords or service-role keys.
SUPABASE_PROJECT_REF=<project-ref>
